# Root local environment template.
# Copy to `.env.local` and fill in the values you need for your machine.

# Local Supabase runtime values used by scripts, tests, and the web app.
API_URL="http://127.0.0.1:54331"
VITE_SUPABASE_URL="http://127.0.0.1:54331"
VITE_SUPABASE_ANON_KEY="<local-anon-key>"
SERVICE_ROLE_KEY="<local-service-role-key>"

# Shared OpenRouter operator settings for local blueprint tooling.
OPENROUTER_API_KEY="<server-only-secret>"
OPENROUTER_IMAGE_MODEL="openai/gpt-image-1"
OPENROUTER_BLUEPRINT_GENERATION_MODEL="openai/gpt-4.1-mini"
OPENROUTER_BLUEPRINT_VERIFIER_MODEL="openai/gpt-4.1-mini"
