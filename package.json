{
    "name": "my2",
    "private": true,
    "workspaces": [
        "packages/*",
        "tests/*",
        "web"
    ],
    "scripts": {
        "dev": "node scripts/dev-mock.mjs",
        "dev:ai:free": "node scripts/dev-ai.mjs free",
        "dev:ai:paid": "node scripts/dev-ai.mjs paid",
        "supabase:restart": "node scripts/supabase-restart.mjs",
        "logs:edge": "node scripts/tail-edge-logs.mjs",
        "setup:local": "node scripts/setup-local.mjs",
        "seed:auth": "node scripts/seed-auth-users.mjs",
        "seed:storage": "node scripts/seed-storage.mjs",
        "seed:ai": "node scripts/seed-ai.mjs",
        "deploy": "node scripts/deploy.mjs",
        "deploy:dev": "npm run deploy -- --env dev",
        "deploy:staging": "npm run deploy -- --env staging",
        "deploy:prod": "npm run deploy -- --env prod",
        "lint": "eslint .",
        "format": "prettier --write .",
        "typecheck": "tsc --noEmit",
        "test:unit": "vitest run tests/api/unit",
        "test:integration": "node scripts/run-mock-tests.mjs integration",
        "test:e2e": "node scripts/run-mock-tests.mjs e2e",
        "test:integration:live:free": "node scripts/run-live-ai.mjs integration free",
        "test:integration:live:paid": "node scripts/run-live-ai.mjs integration paid",
        "test:e2e:live:free": "node scripts/run-live-ai.mjs e2e free",
        "test:e2e:live:paid": "node scripts/run-live-ai.mjs e2e paid",
        "test:live": "npm run test:integration:live:free && npm run test:integration:live:paid && npm run test:e2e:live:free && npm run test:e2e:live:paid",
        "test:all": "npm run lint && npm run typecheck && npm -w web run check && npm run test:unit && npm run test:integration && npm run test:e2e && npm -w web run test:e2e"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "eslint": "^9.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.0.0",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18",
        "wrangler": "^4.71.0"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.98.0"
    }
}
